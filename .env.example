SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SSL_CERT_PATH=./cert.pem
SSL_KEY_PATH=./key.pem

# WebRTC ICE servers used for internet connectivity.
# Default includes a public STUN server. Add TURN for clients behind strict NAT.
# Example:
# WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302,turn:turn.example.com:3478
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
# Optional TURN credentials, used when a turn: or turns: URL is present.
#WEBRTC_TURN_USERNAME=
#WEBRTC_TURN_PASSWORD=

CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FPS=25

SAMPLE_RATE=48000
MIC_CHANNELS=1
SPEAKER_CHANNELS=2
PULSE_SINK_NAME=@DEFAULT_SINK@
PULSE_CAPTURE_SOURCE_NAME=@DEFAULT_SOURCE@
TALKBACK_PLAYBACK_GAIN=5.0

# Face recognition (server-side, using OpenCV Haar + LBPH in Go)
# Set FACE_RECOGNITION_ENABLED=true to activate.
FACE_RECOGNITION_ENABLED=false
# Directory of known faces: one sub-folder per person, containing JPEG/PNG images.
FACE_RECOGNITION_KNOWN_FACES_DIR=./known_faces
# Detect every N frames. Leave unset to auto-calculate (~0.5 s interval at current FPS).
#FACE_RECOGNITION_DETECT_EVERY_N_FRAMES=
# Match confidence threshold in [0..1] (higher = stricter). Default: 0.6
FACE_RECOGNITION_MATCH_THRESHOLD=0.6
# Maximum faces to detect per frame.
FACE_RECOGNITION_MAX_FACES=8
# Require this many consecutive detections before showing a face box.
FACE_RECOGNITION_MIN_CONSECUTIVE_FRAMES=1
# Optional OpenCV haar cascade path override.
#FACE_RECOGNITION_CASCADE_PATH=/usr/share/opencv4/haarcascades/haarcascade_frontalface_default.xml
